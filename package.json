{
  "name": "collab-sandbox",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -e .env -- turbo run dev --parallel",
    "dev:mcp-server": "dotenv -e .env -- npm run dev --workspace mcp-server",
    "db:generate": "dotenv -e .env -- npm run db:generate --workspace @collab-sandbox/db",
    "db:migrate": "dotenv -e .env -- npm run db:migrate --workspace @collab-sandbox/db",
    "db:studio": "dotenv -e .env -- npm run db:studio --workspace @collab-sandbox/db",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.5.6",
    "typescript": "^5.8.2"
  }
}
